  <span class="footer-logo">Rocé Pixan</span>
  <span class="footer-copy">© 2025 · Ashtanga Yoga · San Isidro, Argentina</span>
  <div class="footer-social">
    <a href="https://instagram.com/rocepixan" target="_blank">Instagram</a>
    <a href="https://facebook.com/roceyoga" target="_blank">Facebook</a>
  </div>
</footer>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('visible');
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  function handleForm(e) {
    e.preventDefault();
    const btn = e.target.querySelector('.form-submit');
    btn.textContent = '✓ Mensaje enviado';
    btn.style.background = 'var(--gold)';
    btn.style.color = 'var(--night)';
    btn.disabled = true;
  }
</script>
